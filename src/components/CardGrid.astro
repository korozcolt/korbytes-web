---
import type { CardItem } from "@/data/site";
import { initials } from "@/data/site";
import Chips from "./Chips.astro";

interface Props {
  items: CardItem[];
  featured?: boolean;
}

const { items, featured } = Astro.props;

const gradients = [
  { a: "oklch(0.36 0.140 260)", b: "oklch(0.14 0.030 260)" },
  { a: "oklch(0.68 0.145 85)",  b: "oklch(0.16 0.020 85)" },
  { a: "oklch(0.65 0.125 165)", b: "oklch(0.14 0.025 165)" },
  { a: "oklch(0.72 0.155 215)", b: "oklch(0.16 0.040 215)" },
  { a: "oklch(0.52 0.140 280)", b: "oklch(0.14 0.030 280)" },
];
---

<div class="kb-grid kb-grid-3">
  {items.map((item, idx) => {
    const g = gradients[idx % gradients.length];
    const hasImage = Boolean(item.image);
    return (
      <article class={`kb-project${featured && idx === 0 ? " kb-featured" : ""}${hasImage ? " kb-project--has-image" : ""}`}>
        <div class="kb-project-visual" aria-hidden={hasImage ? "true" : undefined} style={`--vis-a:${g.a};--vis-b:${g.b}`}>
          {hasImage ? (
            <img
              src={item.image}
              alt=""
              loading="lazy"
              decoding="async"
              width="800"
              height="450"
            />
          ) : (
            <span class="kb-project-code">{initials(item.title)}</span>
          )}
        </div>
        <div class="kb-project-body">
          <div class="kb-meta">
            {item.status && <span>{item.status}</span>}
            {item.sector && <span>{item.sector}</span>}
          </div>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <Chips chips={item.chips} />
          {item.href && (
            <p style="margin-top:1.1rem">
              <a class="kb-button-secondary" href={item.href}>Estudio de caso &rarr;</a>
            </p>
          )}
        </div>
      </article>
    );
  })}
</div>

<style>
  .kb-project {
    display: flex;
    flex-direction: column;
    background: var(--kb-bg-raised);
    border: 1px solid var(--kb-line);
    border-radius: var(--kb-radius-md);
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease;
    height: 100%;
  }

  .kb-project:hover {
    border-color: var(--kb-line-brand);
  }

  .kb-featured {
    grid-column: 1 / -1;
    border-color: var(--kb-line-brand);
  }

  .kb-featured .kb-project-body {
    padding: 2rem 2rem 2rem;
  }

  @media (min-width: 880px) {
    .kb-featured {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 0;
      align-items: stretch;
    }
    .kb-featured .kb-project-visual {
      aspect-ratio: auto;
      min-height: 100%;
    }
    .kb-featured .kb-project-body {
      padding: 2.25rem;
    }
  }

  .kb-project-visual {
    position: relative;
    aspect-ratio: 16 / 9;
    background:
      radial-gradient(120% 100% at 20% 0%, var(--vis-a, oklch(0.36 0.140 260)) 0%, transparent 60%),
      linear-gradient(180deg, var(--vis-b, oklch(0.14 0.030 260)) 0%, var(--kb-bg-ink) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
  }

  .kb-project-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(oklch(1 0 0 / 0.04) 1px, transparent 1px),
      linear-gradient(90deg, oklch(1 0 0 / 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    background-position: -1px -1px;
    mask-image: radial-gradient(120% 80% at 50% 50%, black, transparent 75%);
    pointer-events: none;
  }

  .kb-project-code {
    font-family: "JetBrains Mono", monospace;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--kb-text-strong);
    text-shadow: 0 2px 24px oklch(0 0 0 / 0.4);
    z-index: 1;
  }

  .kb-project--has-image .kb-project-visual {
    background: var(--kb-bg-ink);
  }

  .kb-project--has-image .kb-project-visual::after {
    display: none;
  }

  .kb-project-visual img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s ease;
  }

  .kb-project:hover .kb-project-visual img {
    transform: scale(1.03);
  }

  .kb-project-body {
    padding: 1.5rem 1.5rem 1.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
  }

  .kb-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.2rem;
  }

  .kb-meta span {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.25rem 0.55rem;
    border-radius: var(--kb-radius-full);
    background: oklch(0.62 0.015 260 / 0.10);
    color: var(--kb-text-muted);
    letter-spacing: 0.02em;
  }

  .kb-project h3 {
    margin: 0;
    font-family: "Space Grotesk", "DM Sans", system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--kb-text-strong);
    line-height: 1.25;
  }

  .kb-project p {
    margin: 0;
    color: var(--kb-text-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .kb-button-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--kb-cyan);
    font-size: 0.92rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .kb-button-secondary:hover {
    color: var(--kb-cyan-soft);
    gap: 0.55rem;
  }
</style>
