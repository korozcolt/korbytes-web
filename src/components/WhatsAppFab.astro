---
import { whatsapp } from "@/data/site";

interface Props {
  message: string;
}

const { message } = Astro.props;
---

<a class="kb-wa-fab" href={whatsapp(message)} target="_blank" rel="noopener" aria-label="Escríbenos por WhatsApp">
  <span class="kb-wa-fab__pulse" aria-hidden="true"></span>
  <i class="ph ph-whatsapp-logo" aria-hidden="true"></i>
</a>

<style>
  .kb-wa-fab {
    position: fixed;
    right: clamp(16px, 3vw, 28px);
    bottom: clamp(16px, 3vw, 28px);
    z-index: 100;
    width: 60px; height: 60px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #25d366;
    color: white;
    font-size: 1.7rem;
    box-shadow: 0 4px 24px rgba(37, 211, 102, 0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    border: 2px solid rgba(255, 255, 255, 0.18);
  }
  .kb-wa-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 32px rgba(37, 211, 102, 0.65);
  }
  .kb-wa-fab:active { transform: scale(0.96); }
  .kb-wa-fab__pulse {
    position: absolute; inset: 0;
    border-radius: 50%;
    background: #25d366;
    animation: wa-pulse 2.4s ease-out infinite;
    z-index: -1;
    will-change: transform, opacity;
  }
  @keyframes wa-pulse {
    0%   { transform: scale(1);   opacity: 0.6; }
    70%  { transform: scale(1.65); opacity: 0; }
    100% { transform: scale(1.65); opacity: 0; }
  }
</style>
