---
import { whatsapp } from "@/data/site";

interface Props {
  message: string;
}

const { message } = Astro.props;
---

<a class="kb-wa-fab" href={whatsapp(message)} target="_blank" rel="noopener" aria-label="Escríbenos por WhatsApp">
  <span class="kb-wa-fab__pulse"></span>
  <!-- Logo oficial WhatsApp: burbuja + teléfono -->
  <svg width="44" height="44" viewBox="0 0 24 24" aria-hidden="true">
    <path fill="white" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path fill="white" d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.535 5.858L0 24l6.334-1.513A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.845 0-3.57-.484-5.063-1.332l-.363-.214-3.762.987 1.005-3.662-.236-.375A9.96 9.96 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
  </svg>
</a>

<style>
  .kb-wa-fab {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 100;
    width: 60px;
    height: 60px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #25d366;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }

  .kb-wa-fab:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 28px rgba(37, 211, 102, 0.65);
  }

  .kb-wa-fab:active {
    transform: scale(0.96);
  }

  .kb-wa-fab__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #25d366;
    animation: wa-pulse 2.4s ease-out infinite;
    z-index: -1;
  }

  @keyframes wa-pulse {
    0%   { transform: scale(1);   opacity: 0.6; }
    70%  { transform: scale(1.65); opacity: 0; }
    100% { transform: scale(1.65); opacity: 0; }
  }
</style>
