---
import { whatsapp } from "@/data/site";

interface Props {
  message: string;
}

const { message } = Astro.props;
---

<a class="kb-wa-fab" href={whatsapp(message)} target="_blank" rel="noopener" aria-label="Escríbenos por WhatsApp">
  <span class="kb-wa-fab__pulse"></span>
  <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true" fill="none">
    <path fill="white" d="M19.11 17.53c-.28-.14-1.64-.81-1.89-.9-.25-.09-.44-.14-.62.14-.19.28-.71.9-.87 1.08-.16.19-.32.21-.6.07-.28-.14-1.16-.43-2.21-1.37-.82-.73-1.38-1.64-1.54-1.91-.16-.28-.02-.43.12-.57.12-.12.28-.32.41-.48.14-.16.19-.28.28-.46.09-.19.05-.35-.02-.49-.07-.14-.62-1.5-.85-2.06-.22-.53-.45-.46-.62-.47l-.53-.01c-.19 0-.49.07-.74.35-.25.28-.97.95-.97 2.31 0 1.36.99 2.67 1.13 2.86.14.19 1.95 2.98 4.73 4.18.66.29 1.17.46 1.57.59.66.21 1.26.18 1.74.11.53-.08 1.64-.67 1.87-1.32.23-.65.23-1.2.16-1.32-.07-.12-.25-.19-.53-.33z"/>
    <path fill="white" d="M16.02 5.33c-5.89 0-10.69 4.79-10.69 10.69 0 1.89.5 3.73 1.46 5.35L5.33 26.67l5.42-1.42c1.57.86 3.35 1.31 5.27 1.31h.01c5.89 0 10.69-4.79 10.69-10.69 0-2.86-1.11-5.54-3.14-7.56-2.02-2.02-4.7-3.14-7.56-3.14zm0 19.43h-.01c-1.7 0-3.37-.46-4.82-1.34l-.35-.21-3.21.84.86-3.13-.23-.36a8.9 8.9 0 0 1-1.37-4.76c0-4.91 3.99-8.9 8.9-8.9 2.38 0 4.61.93 6.29 2.61a8.84 8.84 0 0 1 2.61 6.29c0 4.91-3.99 8.9-8.67 8.96z"/>
  </svg>
</a>

<style>
  .kb-wa-fab {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 100;
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #25d366;
    color: white;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }

  .kb-wa-fab:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 28px rgba(37, 211, 102, 0.6);
  }

  .kb-wa-fab:active {
    transform: scale(0.96);
  }

  .kb-wa-fab__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #25d366;
    animation: wa-pulse 2.4s ease-out infinite;
    z-index: -1;
  }

  @keyframes wa-pulse {
    0%   { transform: scale(1);   opacity: 0.6; }
    70%  { transform: scale(1.6); opacity: 0; }
    100% { transform: scale(1.6); opacity: 0; }
  }
</style>
