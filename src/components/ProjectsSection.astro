---
import type { CardItem } from "@/data/site";
import CardGrid from "./CardGrid.astro";
import SectionHead from "./SectionHead.astro";

interface Props {
  title: string;
  items: CardItem[];
  moreHref?: string;
  featured?: boolean;
}

const { title, items, moreHref, featured } = Astro.props;
---

<section class="kb-section kb-band">
  <div class="kb-container kb-projects-stack">
    <SectionHead
      badge="Proyectos"
      title={title}
      text="Fichas resumidas para mostrar alcance, sector y madurez sin publicar métricas no verificadas ni claims sensibles."
    />
    <div data-reveal-stagger>
      <CardGrid items={items} featured={featured} />
    </div>
    {moreHref && <div class="kb-more-link"><a href={moreHref}>Explorar proyectos &rarr;</a></div>}
  </div>
</section>
