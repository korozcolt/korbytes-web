---
import { navItems, whatsapp } from "@/data/site";

interface Props {
  current: string;
}

const { current } = Astro.props;
---

<a class="kb-skip" href="#main-content">Saltar al contenido principal</a>
<nav class="kb-nav" aria-label="Navegación principal">
  <div class="kb-container">
    <div class="kb-nav-inner">
      <a class="kb-logo" href="/" aria-label="KOR Bytes inicio">
        <img src="/images/logo-oficial-dark.png" width="600" height="200" alt="KOR Bytes S.A.S." decoding="async" fetchpriority="high" />
      </a>
      <div class="kb-nav-links">
        {navItems.map(([label, href]) => (
          <a href={href} aria-current={href === current ? "page" : undefined}>{label}</a>
        ))}
      </div>
      <a class="kb-nav-cta" href={whatsapp("Hola KOR Bytes, quiero una consultoria para mi proyecto digital.")} target="_blank" rel="noopener">
        Hablar por WhatsApp
      </a>
      <button class="kb-menu-button" type="button" id="mobile-menu-btn" aria-expanded="false" aria-controls="mobile-menu" aria-label="Abrir menú">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="kb-mobile-menu" id="mobile-menu">
      {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
      <a href={whatsapp("Hola KOR Bytes, quiero una consultoria para mi proyecto digital.")} target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</nav>
