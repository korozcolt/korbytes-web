---
import type { PageData } from "@/data/site";
import { whatsapp } from "@/data/site";

interface Props {
  page: PageData;
}

const { page } = Astro.props;
---

<header class="kb-hero ink-surface">
  <canvas id="kb-particles" aria-hidden="true"></canvas>
  <div class="kb-container kb-hero-grid">
    <div>
      <span class="kb-eyebrow">{page.eyebrow}</span>
      <h1>{page.h1}</h1>
      <p class="kb-lead">{page.lead}</p>
      <div class="kb-actions">
        <a class="kb-button-primary" href={whatsapp(page.cta)} target="_blank" rel="noopener">Hablar del proyecto</a>
        <a class="kb-button-secondary" href={page.secondary[0]}>{page.secondary[1]}</a>
      </div>
      <div class="kb-stat-row">
        <div class="kb-stat"><strong>PASS</strong><span>Productos verticales reutilizables</span></div>
        <div class="kb-stat"><strong>Laravel</strong><span>Arquitectura para operación real</span></div>
        <div class="kb-stat"><strong>LATAM</strong><span>Base en Sucre, trabajo remoto</span></div>
      </div>
    </div>
    <div class="kb-orbit" aria-hidden="true">
      <div id="kb-three-scene"></div>
      <div class="kb-orbit-line"></div>
      <div class="kb-orbit-line"></div>
      <div class="kb-orbit-line"></div>
    </div>
  </div>
</header>

<script is:inline>
  (function() {
    const canvas = document.getElementById("kb-particles");
    if (!canvas || matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const ctx = canvas.getContext("2d");
    let w, h, particles = [];
    const COUNT = 60;
    const MAX_DIST = 120;

    function resize() {
      const rect = canvas.parentElement.getBoundingClientRect();
      w = canvas.width = rect.width;
      h = canvas.height = rect.height;
    }
    resize();
    window.addEventListener("resize", resize);

    for (let i = 0; i < COUNT; i++) {
      particles.push({ x: Math.random() * w, y: Math.random() * h, vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4 });
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      for (let i = 0; i < COUNT; i++) {
        const p = particles[i];
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 1.5, 0, Math.PI * 2);
        ctx.fillStyle = "oklch(0.55 0.120 260 / 0.35)";
        ctx.fill();
        for (let j = i + 1; j < COUNT; j++) {
          const q = particles[j];
          const dx = p.x - q.x, dy = p.y - q.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MAX_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.strokeStyle = `oklch(0.55 0.120 260 / ${(1 - dist / MAX_DIST) * 0.15})`;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }
    draw();
  })();
</script>

<script is:inline>
  (async function() {
    const container = document.getElementById("kb-three-scene");
    if (!container || matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    try {
      const THREE = await import("https://cdn.jsdelivr.net/npm/three@0.168.0/build/three.module.js");
      const w = container.clientWidth, h = container.clientHeight;
      if (w < 200 || h < 200) return;
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(45, w / h, 0.1, 100);
      camera.position.set(0, 0, 5.5);
      const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setSize(w, h);
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
      container.appendChild(renderer.domElement);
      const geom = new THREE.TorusKnotGeometry(1.6, 0.5, 128, 24);
      const edges = new THREE.EdgesGeometry(geom);
      const mat = new THREE.LineBasicMaterial({ color: 0x4488ee, transparent: true, opacity: 0.25 });
      const mesh = new THREE.LineSegments(edges, mat);
      scene.add(mesh);
      const innerGeom = new THREE.TorusKnotGeometry(1.6, 0.5, 64, 16);
      const innerMat = new THREE.MeshBasicMaterial({ color: 0x2266cc, wireframe: true, transparent: true, opacity: 0.08 });
      const inner = new THREE.Mesh(innerGeom, innerMat);
      scene.add(inner);
      function animate() {
        requestAnimationFrame(animate);
        mesh.rotation.x += 0.004;
        mesh.rotation.y += 0.007;
        inner.rotation.x += 0.003;
        inner.rotation.y += 0.005;
        renderer.render(scene, camera);
      }
      animate();
      const ro = new ResizeObserver(() => {
        const nw = container.clientWidth, nh = container.clientHeight;
        camera.aspect = nw / nh;
        camera.updateProjectionMatrix();
        renderer.setSize(nw, nh);
      });
      ro.observe(container);
    } catch (e) { /* Three.js failed to load — degrade gracefully */ }
  })();
</script>
