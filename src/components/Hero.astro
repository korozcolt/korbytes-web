---
import type { PageData } from "@/data/site";
import { whatsapp } from "@/data/site";

interface Props {
  page: PageData;
}

const { page } = Astro.props;
---

<header class="kb-hero surface-ink" id="hero">
  <!-- Three.js scene: orbital architecture visualization -->
  <canvas id="kb-hero-canvas" aria-hidden="true"></canvas>

  <!-- Animated SVG: schematic overlay (orbit traces) -->
  <svg class="kb-hero-traces" aria-hidden="true" viewBox="0 0 800 800" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id="kb-trace" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="oklch(0.78 0.155 215)" stop-opacity="0.45"/>
        <stop offset="80%" stop-color="oklch(0.78 0.155 215)" stop-opacity="0"/>
      </radialGradient>
    </defs>
    <g fill="none" stroke="url(#kb-trace)" stroke-width="1">
      <circle cx="400" cy="400" r="120"/>
      <circle cx="400" cy="400" r="220" stroke-dasharray="2 6"/>
      <circle cx="400" cy="400" r="340" stroke-dasharray="1 14"/>
    </g>
  </svg>

  <div class="kb-container">
    <div class="kb-hero-grid" data-reveal-stagger>
      <!-- BIG TYPE STACK ─ left aligned, never centered -->
      <div class="kb-hero-copy">
        <div class="kb-hero-kicker">
          <span class="kb-status kb-status--production">Operando desde 2019</span>
          <span class="kb-hero-loc">Sincelejo, Sucre · LATAM</span>
        </div>

        <h1 class="kb-hero-title">
          <span class="kb-hero-line">
            <span class="kb-hero-word">Software</span> <span class="kb-hero-word kb-hero-word--accent">operativo,</span>
          </span>
          <span class="kb-hero-line">
            <span class="kb-hero-word">productos</span> <span class="kb-hero-word kb-hero-word--italic">verticales</span>
          </span>
          <span class="kb-hero-line">
            <span class="kb-hero-word kb-hero-word--accent">y</span> <span class="kb-hero-word">sistemas</span> <span class="kb-hero-word kb-hero-word--italic">que</span>
          </span>
          <span class="kb-hero-line">
            <span class="kb-hero-word">sí aguantan</span> <span class="kb-hero-word kb-hero-word--accent">la operación.</span>
          </span>
        </h1>

        <p class="kb-lead kb-hero-lead">{page.lead}</p>

        <div class="kb-hero-actions">
          <a class="kb-btn kb-btn--primary" data-magnetic href={whatsapp(page.cta)} target="_blank" rel="noopener">
            <i class="ph ph-chat-teardrop-text" aria-hidden="true"></i>
            Hablar del proyecto
          </a>
          <a class="kb-btn kb-btn--ghost" data-magnetic href={page.secondary[0]}>
            <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
            {page.secondary[1]}
          </a>
        </div>

        <!-- Compact stat row (no hero-metric template) -->
        <dl class="kb-hero-stats">
          <div>
            <dt class="kb-mono">Productos verticales</dt>
            <dd><span class="kb-stat-num">11</span><span class="kb-stat-suf">PASS</span></dd>
          </div>
          <div>
            <dt class="kb-mono">Arquitectura</dt>
            <dd><span class="kb-stat-num">Laravel</span><span class="kb-stat-suf">+ Filament</span></dd>
          </div>
          <div>
            <dt class="kb-mono">Cobertura</dt>
            <dd><span class="kb-stat-num">LATAM</span><span class="kb-stat-suf">remoto-first</span></dd>
          </div>
        </dl>
      </div>

      <!-- RIGHT: cinematic 3D visualization with overlay info card -->
      <div class="kb-hero-visual">
        <div class="kb-hero-canvas-wrap" id="kb-three-scene"></div>

        <div class="kb-hero-overlay-card">
          <div class="kb-hero-overlay-row">
            <span class="kb-status kb-status--released">NEXUS <span class="kb-mono">/ OMS</span></span>
            <span class="kb-mono kb-mono--sm">v1.4 — producción</span>
          </div>
          <p class="kb-hero-overlay-text">
            Middleware <span class="kb-wordmark">VTEX ↔ ICG</span> sincronizando pedidos, inventario y estados para retail omnicanal.
          </p>
          <div class="kb-hero-overlay-foot">
            <span class="kb-chip kb-chip--amber">Middleware</span>
            <span class="kb-chip kb-chip--ink">Retail</span>
            <a href="/casos/nexus-oms-integracion-vtex-icg" class="kb-hero-overlay-link">
              Ver caso <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
            </a>
          </div>
        </div>

        <!-- Floating data tickers (surprise element) -->
        <div class="kb-hero-ticker kb-hero-ticker--top" aria-hidden="true">
          <span class="kb-mono">↗ 247 ops/min</span>
        </div>
        <div class="kb-hero-ticker kb-hero-ticker--bottom" aria-hidden="true">
          <span class="kb-mono">⟳ sync 0.3s</span>
        </div>
      </div>
    </div>

    <!-- Bottom reveal ribbon: marquee of tech vocabulary, single shot -->
    <div class="kb-hero-marquee" aria-hidden="true">
      <div class="kb-hero-marquee-track" id="kb-hero-marquee">
        <span>Laravel</span><i>·</i>
        <span>Filament</span><i>·</i>
        <span>Livewire</span><i>·</i>
        <span>PASS Core</span><i>·</i>
        <span>n8n</span><i>·</i>
        <span>Dokploy</span><i>·</i>
        <span>VPS</span><i>·</i>
        <span>Redis</span><i>·</i>
        <span>Postgres</span><i>·</i>
        <span>WordPress</span><i>·</i>
        <span>Shopify</span><i>·</i>
        <span>MercadoPago</span><i>·</i>
        <span>Wompi</span><i>·</i>
        <span>OpenClaw</span><i>·</i>
        <span>Gemini</span><i>·</i>
      </div>
    </div>
  </div>
</header>

<!-- Three.js + ancillary scene (loaded only here to keep payloads small on inner pages) -->
<script>
  import { initHeroScene } from "@/scripts/hero-scene";
  initHeroScene();
</script>
