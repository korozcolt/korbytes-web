---
import type { PageData } from "@/data/site";
import { whatsapp } from "@/data/site";

interface Props {
  page: PageData;
}

const { page } = Astro.props;
---

<header class="kb-hero surface-ink" id="hero">
  <!-- Animated SVG: schematic overlay (orbit traces) -->
  <svg class="kb-hero-traces" aria-hidden="true" viewBox="0 0 800 800" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id="kb-trace" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="oklch(0.78 0.155 215)" stop-opacity="0.45"/>
        <stop offset="80%" stop-color="oklch(0.78 0.155 215)" stop-opacity="0"/>
      </radialGradient>
    </defs>
    <g fill="none" stroke="url(#kb-trace)" stroke-width="1">
      <circle cx="400" cy="400" r="120"/>
      <circle cx="400" cy="400" r="220" stroke-dasharray="2 6"/>
      <circle cx="400" cy="400" r="340" stroke-dasharray="1 14"/>
    </g>
  </svg>  <div class="kb-container">
    <div class="kb-hero-grid">
      <!-- BIG TYPE STACK ─ left aligned, never centered -->
      <div class="kb-hero-copy">
        <div class="kb-hero-kicker">
          <span class="kb-status kb-status--production">Operando desde 2019</span>
          <span class="kb-hero-loc">Sincelejo, Sucre · LATAM</span>
        </div>

        <h1 class="kb-hero-title">
          <span class="kb-hero-line">
            <span class="kb-hero-word">Software</span> <span class="kb-hero-word kb-hero-word--accent">operativo,</span>
          </span>
          <span class="kb-hero-line">
            <span class="kb-hero-word">productos</span> <span class="kb-hero-word kb-hero-word--italic">verticales</span>
          </span>
          <span class="kb-hero-line">
            <span class="kb-hero-word kb-hero-word--accent">y</span> <span class="kb-hero-word">sistemas</span> <span class="kb-hero-word kb-hero-word--italic">que</span>
          </span>
          <span class="kb-hero-line">
            <span class="kb-hero-word">sí aguantan</span> <span class="kb-hero-word kb-hero-word--accent">la operación.</span>
          </span>
        </h1>

        <p class="kb-lead kb-hero-lead">{page.lead}</p>

        <div class="kb-hero-actions">
          <a class="kb-btn kb-btn--primary" data-magnetic href={whatsapp(page.cta)} target="_blank" rel="noopener">
            <i class="ph ph-chat-teardrop-text" aria-hidden="true"></i>
            Hablar del proyecto
          </a>
          <a class="kb-btn kb-btn--ghost" data-magnetic href={page.secondary[0]}>
            <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
            {page.secondary[1]}
          </a>
        </div>

        <!-- Compact stat row (no hero-metric template) -->
        <dl class="kb-hero-stats">
          <div>
            <dt class="kb-mono">Productos verticales</dt>
            <dd><span class="kb-stat-num">11</span><span class="kb-stat-suf">PASS</span></dd>
          </div>
          <div>
            <dt class="kb-mono">Arquitectura</dt>
            <dd><span class="kb-stat-num">Laravel</span><span class="kb-stat-suf">+ Filament</span></dd>
          </div>
          <div>
            <dt class="kb-mono">Cobertura</dt>
            <dd><span class="kb-stat-num">LATAM</span><span class="kb-stat-suf">remoto-first</span></dd>
          </div>
        </dl>
      </div>

      <!-- RIGHT: cinematic 3D visualization with overlay info card -->
      <div class="kb-hero-visual">
        <div class="kb-hero-canvas-wrap" id="kb-three-scene"></div>

        <div class="kb-hero-overlay-card">
          <div class="kb-hero-overlay-row">
            <span class="kb-status kb-status--released">NEXUS <span class="kb-mono">/ OMS</span></span>
            <span class="kb-mono kb-mono--sm">v1.4 — producción</span>
          </div>
          <p class="kb-hero-overlay-text">
            Middleware <span class="kb-wordmark">VTEX ↔ ICG</span> sincronizando pedidos, inventario y estados para retail omnicanal.
          </p>
          <div class="kb-hero-overlay-foot">
            <span class="kb-chip kb-chip--amber">Middleware</span>
            <span class="kb-chip kb-chip--ink">Retail</span>
            <a href="/casos/nexus-oms-integracion-vtex-icg" class="kb-hero-overlay-link">
              Ver caso <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
            </a>
          </div>
        </div>

        <!-- Floating data tickers (surprise element) -->
        <div class="kb-hero-ticker kb-hero-ticker--top" aria-hidden="true">
          <span class="kb-mono">↗ 247 ops/min</span>
        </div>
        <div class="kb-hero-ticker kb-hero-ticker--bottom" aria-hidden="true">
          <span class="kb-mono">⟳ sync 0.3s</span>
        </div>
      </div>
    </div>

    <!-- Bottom reveal ribbon: marquee of tech vocabulary, single shot -->
    <div class="kb-hero-marquee" aria-hidden="true">
      <div class="kb-hero-marquee-track" id="kb-hero-marquee">
        <span>Laravel</span><i>·</i>
        <span>Filament</span><i>·</i>
        <span>Livewire</span><i>·</i>
        <span>PASS Core</span><i>·</i>
        <span>n8n</span><i>·</i>
        <span>Dokploy</span><i>·</i>
        <span>VPS</span><i>·</i>
        <span>Redis</span><i>·</i>
        <span>Postgres</span><i>·</i>
        <span>WordPress</span><i>·</i>
        <span>Shopify</span><i>·</i>
        <span>MercadoPago</span><i>·</i>
        <span>Wompi</span><i>·</i>
        <span>OpenClaw</span><i>·</i>
        <span>Gemini</span><i>·</i>
      </div>
    </div>
  </div>
</header>

<!-- Three.js + ancillary scene (loaded only here to keep payloads small on inner pages) -->
<script>
  import { initHeroScene } from "@/scripts/hero-scene";
  initHeroScene();
</script>

<style>
  /* ── Layout shell ─────────────────────────────────────────── */
  .kb-hero-traces {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .kb-hero-traces {
    z-index: 1;
    opacity: 0.65;
  }

  .kb-hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: center;
    padding-block: clamp(1rem, 3vw, 2rem);
  }

  /* ── Copy column ──────────────────────────────────────────── */
  .kb-hero-copy {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
  }

  .kb-hero-kicker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    align-items: center;
  }
  .kb-hero-loc {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--kb-text-muted);
    letter-spacing: 0.05em;
  }

  .kb-hero-title {
    margin: 0;
    font-family: "Space Grotesk", "DM Sans", system-ui, sans-serif;
    font-size: clamp(2.4rem, 5.6vw, 5.2rem);
    font-weight: 600;
    line-height: 0.96;
    letter-spacing: -0.028em;
    color: var(--kb-text-strong);
    text-wrap: balance;
  }

  .kb-hero-line {
    display: block;
  }

  .kb-hero-word {
    display: inline-block;
  }

  .kb-hero-word--accent {
    color: var(--kb-cyan);
    font-style: italic;
    font-weight: 500;
  }
  .kb-hero-word--italic {
    color: var(--kb-text-muted);
    font-style: italic;
  }

  .kb-hero-lead {
    margin: 0;
    max-width: 60ch;
    color: var(--kb-text-muted);
    font-size: clamp(1.02rem, 1.4vw, 1.2rem);
    line-height: 1.62;
    text-wrap: pretty;
  }

  .kb-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ── Stats row ────────────────────────────────────────────── */
  .kb-hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem 1.25rem;
    margin: 0;
    padding: 1rem 0 0;
    border-top: 1px solid var(--kb-line);
  }
  .kb-hero-stats > div { display: contents; }
  .kb-hero-stats dt {
    margin: 0;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    color: var(--kb-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .kb-hero-stats dd {
    margin: 0.15rem 0 0;
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  .kb-stat-num {
    font-family: "Space Grotesk", "DM Sans", system-ui, sans-serif;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    font-weight: 700;
    color: var(--kb-text-strong);
    letter-spacing: -0.02em;
  }
  .kb-stat-suf {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: var(--kb-cyan);
    font-weight: 500;
  }

  /* ── Right column: 3D visual + overlay card ─────────────── */
  .kb-hero-visual {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    min-height: 320px;
  }
  .kb-hero-canvas-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .kb-hero-overlay-card {
    position: absolute;
    left: 8%;
    bottom: 12%;
    max-width: 360px;
    padding: 1rem 1.15rem;
    border: 1px solid var(--kb-line-strong);
    border-radius: var(--kb-radius-md);
    background: oklch(0.10 0.012 260 / 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--kb-text);
    z-index: 3;
    box-shadow: 0 12px 40px oklch(0 0 0 / 0.45);
  }
  .kb-hero-overlay-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .kb-hero-overlay-text {
    margin: 0.6rem 0 0;
    font-size: 0.92rem;
    color: var(--kb-text-muted);
    line-height: 1.45;
  }
  .kb-hero-overlay-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.8rem;
  }
  .kb-hero-overlay-link {
    margin-left: auto;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--kb-cyan);
    text-decoration: none;
  }
  .kb-hero-overlay-link:hover { color: var(--kb-cyan-soft); }

  /* ── Floating tickers (decorative) ───────────────────────── */
  .kb-hero-ticker {
    position: absolute;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: var(--kb-text-muted);
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--kb-line);
    border-radius: var(--kb-radius-full);
    background: oklch(0.12 0.010 260 / 0.7);
    z-index: 3;
  }
  .kb-hero-ticker--top    { top: 8%;       right: 6%; }
  .kb-hero-ticker--bottom { bottom: 6%;   right: 14%; }

  /* ── Marquee ribbon ──────────────────────────────────────── */
  .kb-hero-marquee {
    position: relative;
    z-index: 2;
    margin-top: clamp(2rem, 5vw, 3.5rem);
    padding-block: 0.85rem;
    border-top: 1px solid var(--kb-line);
    border-bottom: 1px solid var(--kb-line);
    overflow: hidden;
  }
  .kb-hero-marquee-track {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: var(--kb-text-muted);
    white-space: nowrap;
    animation: kb-marquee 60s linear infinite;
  }
  .kb-hero-marquee-track span { flex-shrink: 0; }
  .kb-hero-marquee-track i {
    color: var(--kb-line-strong);
    font-style: normal;
    flex-shrink: 0;
  }
  @keyframes kb-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 980px) {
    .kb-hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .kb-hero-visual {
      aspect-ratio: 16 / 11;
      min-height: 280px;
      max-height: 420px;
    }
    .kb-hero-overlay-card {
      left: 4%;
      max-width: 88%;
    }
    .kb-hero-ticker--top    { right: 4%; }
    .kb-hero-ticker--bottom { right: 6%; }
  }

  @media (max-width: 600px) {
    .kb-hero-stats {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }
    .kb-hero-stats > div {
      display: block;
      padding-block: 0.4rem;
      border-top: 1px dashed var(--kb-line);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kb-hero-marquee-track { animation: none; }
  }
</style>
