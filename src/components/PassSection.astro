---
import type { CardItem } from "@/data/site";
import CardGrid from "./CardGrid.astro";
import SectionHead from "./SectionHead.astro";

interface Props {
  title: string;
  items: CardItem[];
  moreHref?: string;
  featured?: boolean;
}

const { title, items, moreHref, featured } = Astro.props;
---

<section class="kb-section section-warm">
  <div class="kb-container">
    <SectionHead
      badge="PASS"
      title={title}
      text="Productos verticales publicados con su estado real para comunicar visión estratégica sin prometer madurez que todavía no existe."
    />
    <CardGrid items={items} featured={featured} />
    {moreHref && <div class="kb-more-link"><a href={moreHref}>Ver todos los productos PASS &rarr;</a></div>}
  </div>
</section>
