---
import "@/styles/global.css";
import type { PageData } from "@/data/site";
import { SITE, structuredData } from "@/data/site";
import Footer from "@/components/Footer.astro";
import Nav from "@/components/Nav.astro";
import WhatsAppFab from "@/components/WhatsAppFab.astro";

interface Props {
  page: PageData;
}

const { page } = Astro.props;
const canonical = new URL(page.route, SITE).toString();
const schema = JSON.stringify(structuredData(page, canonical));
---

<!doctype html>
<html class="dark" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <meta name="author" content="KOR Bytes S.A.S." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.description} />
    <meta property="og:image" content={`${SITE}/images/logo-oficial.png`} />
    <meta property="og:image:alt" content="KOR Bytes S.A.S. software operativo y productos PASS" />
    <meta property="og:locale" content="es_CO" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={page.title} />
    <meta name="twitter:description" content={page.description} />
    <meta name="twitter:image" content={`${SITE}/images/logo-oficial.png`} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#031022" />
    <link rel="preload" as="image" href="/images/logo-oficial-dark.png" fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-blocking font load: preload → swap to stylesheet after parse -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Space+Grotesk:wght@500;700&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Space+Grotesk:wght@500;700&display=swap" /></noscript>
    <!-- GA4: config queued immediately, library loads async without blocking render -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "G-FGEEJ8RSN0");
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FGEEJ8RSN0"></script>
    <script is:inline type="application/ld+json" set:html={schema}></script>
  </head>
  <body>
    <Nav current={page.nav} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <WhatsAppFab message={page.cta} />
    <script>
      const mobileMenuBtn = document.getElementById("mobile-menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener("click", () => {
          const isOpen = mobileMenu.classList.toggle("is-open");
          mobileMenuBtn.setAttribute("aria-expanded", String(isOpen));
        });

        mobileMenu.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            mobileMenu.classList.remove("is-open");
            mobileMenuBtn.setAttribute("aria-expanded", "false");
          });
        });
      }

    </script>
  </body>
</html>
